# Alchemy RPC — dedicated app(s) for "Robinhood Chain Mainnet".
# Comma-separated list; requests round-robin across every URL listed
# here (a single URL works fine too). NEVER commit real keys — this
# file is a template only.
#
# Note: Alchemy enforces throughput (CU/s) at the ACCOUNT level, not
# per-app, so listing several apps from the SAME account does not
# multiply total capacity (see alchemy.com/docs/reference/throughput).
# Multiple URLs only actually help if they come from different
# accounts/providers — otherwise it's harmless but won't speed things up.
# Every URL must be robinhood-mainnet — never mix eth-mainnet or other chains.
ALCHEMY_RPC_URLS=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY_1,https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY_2

RH_CHAIN_ID=4663

# Own database — separate from hoodscan's, on purpose (see docs/PLAN.md).
DATABASE_URL=postgresql://hoodscan_indexer:hoodscan_indexer@localhost:5434/hoodscan_indexer

# Keep concurrency modest — large bursts (e.g. 100) trigger Alchemy 429s.
# For N separate Free accounts, roughly: RPS ≈ 20*N, concurrency ≈ 0.4*RPS
BACKFILL_CONCURRENCY=15
BACKFILL_BATCH_SIZE=200

# Alchemy Free tier ~25 req/s account-wide (not per key). Multiple apps
# on the SAME account do not multiply this. Stay under the dashboard limit.
RPC_MAX_REQUESTS_PER_SECOND=20

# Retries per block on 429 / transient errors (exponential backoff).
RPC_FETCH_MAX_ATTEMPTS=8

# Optional gap-filler rate limits (pnpm run fill-gaps)
GAP_FILL_CONCURRENCY=5
GAP_FILL_MAX_RPS=5
