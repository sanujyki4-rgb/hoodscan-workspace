generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Block & Transaction models below are kept IDENTICAL to
// hoodscan/packages/database/prisma/schema.prisma on purpose —
// see docs/PLAN.md section 4 ("cutover plan"). Do not diverge
// these two models without updating that doc.
// ─────────────────────────────────────────────────────────────

model Block {
  number          BigInt   @id
  hash            String   @unique
  parentHash      String
  timestamp       DateTime
  gasUsed         BigInt
  gasLimit        BigInt
  baseFeePerGas   BigInt
  l1BlockNumber   BigInt
  sendCount       BigInt
  sendRoot        String
  size            Int
  txCount         Int
  isFinalized     Boolean  @default(false)

  transactions    Transaction[]

  @@index([timestamp])
}

model Transaction {
  hash                  String   @id
  blockNumber           BigInt
  block                 Block    @relation(fields: [blockNumber], references: [number])
  transactionIndex      Int

  fromAddress           String
  toAddress              String?  // nullable: contract deployment
  nonce                 BigInt
  value                 Decimal  @db.Decimal(38, 0) // wei, can be very large
  gas                   BigInt
  gasPrice              Decimal? @db.Decimal(38, 0)
  maxFeePerGas          Decimal? @db.Decimal(38, 0)
  maxPriorityFeePerGas  Decimal? @db.Decimal(38, 0)

  input                 String   // raw calldata, can be long
  functionSelector      String?  // first 4 bytes of input, for fast filtering
  txType                String   // '0x0', '0x2', '0x6a', etc.

  @@index([blockNumber])
  @@index([fromAddress])
  @@index([toAddress])
  @@index([functionSelector])
}

// ─────────────────────────────────────────────────────────────
// Everything below this line is SPECIFIC to hoodscan-indexer
// and intentionally NOT part of hoodscan's schema — this table
// only makes sense while a standalone backfill is in progress.
// ─────────────────────────────────────────────────────────────

// Tracks backfill progress so the process can be safely killed
// and resumed without re-scanning already-indexed ranges.
// Single-row table in practice (id = "main"), but modeled as a
// table (not a file) so progress survives across machines/restarts
// consistently with the rest of the data.
model BackfillProgress {
  id                String   @id @default("main")
  lastIndexedBlock  BigInt   @default(0)
  targetBlock       BigInt? // chain tip at the time backfill started, for progress %
  updatedAt         DateTime @updatedAt
}
